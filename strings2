def checking_punc(str,lower=False):
   new_str = ''
   for char in str:
       if char.isalpha() and not lower:
           new_str += char
       elif char.isalpha() and lower:
           new_str+= char.lower()
   return new_str


  






def checking_words(str2):
   longest_word = ''
   longest_length = 0
   smallest_word = ''
   smallest_length = 20000
   word_list = str2.split()
   print(word_list)
   for word in word_list:
       new_word = checking_punc(word)


       length = len(new_word)
       if length>longest_length:
           longest_word = new_word
           longest_length = length


       elif length<smallest_length:
           smallest_word = new_word
           smallest_length = length
       return longest_word,smallest_word


      






          




